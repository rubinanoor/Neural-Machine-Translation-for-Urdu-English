    "# Urdu-English NMT — Tokenizer Ablation\n",
    "### Notebook 02 — Phase 2 (Post Mid-Report)\n",
    "\n",
    "Trains three SentencePiece BPE tokenizer models on the Urdu training corpus.\n",
    "\n",
    "**Research Question:** Does BPE vocabulary size (8k / 16k / 32k) affect Urdu→English translation quality?\n",
    "\n",
    "**NOTE:** You do NOT need to run this notebook for the mid-report. It is needed for Phase 2 (the full ablation study for the final submission).\n",
    "\n",
    "| Model | Vocab Size | Expected Training Time |\n",
    "|-------|-----------|----------------------|\n",
    "| `urdu_bpe_8k` | 8,000 | ~3 minutes |\n",
    "| `urdu_bpe_16k` | 16,000 | ~4 minutes |\n",
    "| `urdu_bpe_32k` | 32,000 | ~5 minutes |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 1: Setup\n",
    "# ============================================================\n",
    "\n",
    "import os, sys\n",
    "import subprocess\n",
    "\n",
    "subprocess.run([sys.executable, '-m', 'pip', 'install', '-q', 'sentencepiece'], capture_output=True)\n",
    "\n",
    "PROJECT_ROOT = '/kaggle/working/urdu-en-nmt'\n",
    "if PROJECT_ROOT not in sys.path:\n",
    "    sys.path.insert(0, PROJECT_ROOT)\n",
    "\n",
    "os.environ['NMT_DATA_DIR']      = '/kaggle/working/data'\n",
    "os.environ['NMT_TOKENIZER_DIR'] = '/kaggle/working/tokenizer'\n",
    "\n",
    "os.makedirs('/kaggle/working/tokenizer', exist_ok=True)\n",
    "\n",
    "print('Ready.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 2: Train all three BPE models\n",
    "# Calls tokenizer/train_spm.py\n",
    "# ============================================================\n",
    "\n",
    "from tokenizer.train_spm import run_tokenizer_training\n",
    "\n",
    "run_tokenizer_training(\n",
    "    vocab_sizes   = [8_000, 16_000, 32_000],\n",
    "    data_dir      = os.environ['NMT_DATA_DIR'],\n",
    "    tokenizer_dir = os.environ['NMT_TOKENIZER_DIR'],\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELL 3: Compare tokenization across vocab sizes\n",
    "# Shows how the same Urdu sentence is segmented differently\n",
    "# depending on vocabulary size. Include this table in your report.\n",
    "# ============================================================\n",
    "\n",
    "import sentencepiece as spm\n",
    "\n",
    "# Sample Urdu sentences of varying complexity\n",
    "test_sentences = [\n",
    "    'میں آپ سے بات کرنا چاہتا ہوں',              # Short / conversational\n",
    "    'اقوام متحدہ نے اس فیصلے کی مخالفت کی',       # Medium / formal\n",
    "    'کمپیوٹر پروگرامنگ کی بنیادی باتیں سیکھنا',    # Technical\n",
    "]\n",
    "\n",
    "tokenizer_dir = os.environ['NMT_TOKENIZER_DIR']\n",
    "\n",
    "print(f\"{'Sentence':<45} {'Vocab':<8} {'Tokens':<8} {'Pieces'}\")\n",
    "print('-' * 95)\n",
    "\n",
    "for sent in test_sentences:\n",
    "    for vocab_k in [8, 16, 32]:\n",
    "        model_path = os.path.join(tokenizer_dir, f'urdu_bpe_{vocab_k}k.model')\n",
    "        if os.path.exists(model_path):\n",
    "            sp = spm.SentencePieceProcessor()\n",
    "            sp.Load(model_path)\n",
    "            pieces = sp.EncodeAsPieces(sent)\n",
    "            display_sent = (sent[:42] + '...') if len(sent) > 45 else sent\n",
    "            label = f'vocab={vocab_k}k'\n",
    "            print(f\"{display_sent:<45} {label:<8} {len(pieces):<8} {' | '.join(pieces[:10])}\")\n",
    "    print()"
   ]
  }
 ],
